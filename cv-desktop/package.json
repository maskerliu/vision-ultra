    "express-http-proxy": "^2.1.2",
    "formidable": "^3.5.4",
    "http2-express": "^1.1.0",
    "inversify": "^7.11.0",
    "json-bigint": "^1.0.0",
    "level-transcoder": "1.0.1",
    "pouchdb-adapter-leveldb": "^9.0.0",
    "pouchdb-find": "^9.0.0",
    "pouchdb-node": "^9.0.0",
    "reflect-metadata": "^0.2.2",
    "sockjs": "^0.3.24",
    "systeminformation": "^5.31.1",
    "tcp-port-used": "^1.0.2"
  },
