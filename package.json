{
  "name": "vision-ultra",
  "version": "1.0.0",
  "author": {
    "name": "maskerliu",
    "email": "lynx.chrisliu@gmail.com"
  },
  "description": "VisionUltra",
  "type": "module",
  "license": "UNLICENSED",
  "workspaces": [
    "cv-desktop"
  ],
  "scripts": {
    "test": "yarn workspace cv-desktop run test",
    "dev": "yarn workspace cv-desktop run dev",
    "build": "yarn workspace cv-desktop run build",
    "build:clean": "yarn workspace cv-desktop run build:clean",
    "publish": "node --import tsx .build-scripts/publish.ts",
    "pkg": "yarn workspace cv-desktop run pkg",
    "pub": "yarn workspace cv-desktop run pub",
    "pub:full": "yarn workspace cv-desktop run pub:full",
    "rebuild": "yarn electron-builder install-app-deps",
    "electron-rebuild": "yarn workspace cv-desktop run electron-rebuild",
    "opencv:build": "yarn workspace cv-desktop run opencv:build",
    "updateServer": "http-server build/ -p 4000 --cors -c-1"
  },
  "resolutions": {
    "apache-arrow": "18.1.0",
    "leveldown": "6.1.1",
    "make-fetch-happen": "15.0.2",
    "webpack": "5.105.3",
    "glob": "11.0.3",
    "readable-stream": "3.6.0",
    "debug": "4.4.3",
    "abstract-leveldown": "7.2.0",
    "raw-body": "3.0.1",
    "iconv-lite": "0.7.0",
    "negotiator": "1.0.0",
    "ms": "2.1.3",
    "level-supports": "2.0.1",
    "buffer": "6.0.3",
    "http-errors": "2.0.1",
    "node-gyp": "11.5.0",
    "yargs": "17.6.2",
    "https-proxy-agent": "7.0.6",
    "which": "5.0.0",
    "emoji-regex": "9.2.2",
    "node-fetch": "2.7.0",
    "onnxruntime-common": "1.23.2"
  },
  "packageManager": "yarn@4.12.0"
}
