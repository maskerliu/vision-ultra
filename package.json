{
  "name": "vision-ultra",
  "version": "1.0.0",
  "author": {
    "name": "maskerliu",
    "email": "lynx.chrisliu@gmail.com"
  },
  "description": "VisionUltra",
  "type": "module",
  "license": "UNLICENSED",
  "workspaces": [
    "cv-desktop",
    "model-train"
  ],
  "scripts": {
    "test": "yarn workspace cv-desktop run test",
    "dev": "yarn workspace cv-desktop run dev",
    "build": "yarn workspace cv-desktop run build",
    "build:clean": "yarn workspace cv-desktop run build:clean",
    "publish": "node --import tsx .build-scripts/publish.ts",
    "pkg": "yarn workspace cv-desktop run pkg",
    "pub": "yarn workspace cv-desktop run pub",
    "pub:full": "yarn workspace cv-desktop run pub:full",
    "rebuild": "yarn electron-builder install-app-deps",
    "electron-rebuild": "yarn workspace cv-desktop run electron-rebuild",
    "opencv:build": "yarn workspace cv-desktop run opencv:build",
    "updateServer": "http-server build/ -p 4000 --cors -c-1"
  },
  "config": {
    "port": 8884,
    "protocol": "https"
  },
  "permissions": {
    "video-capture": {
      "description": "Required to access camera"
    }
  },
  "resolutions": {
    "leveldown": "6.1.1",
    "make-fetch-happen": "15.0.2",
    "webpack": "5.102.1",
    "@types/node": "22.7.7",
    "glob": "11.0.3",
    "readable-stream": "3.6.0",
    "debug": "4.3.4",
    "abstract-leveldown": "7.2.0",
    "raw-body": "3.0.1",
    "iconv-lite": "0.7.0",
    "negotiator": "1.0.0",
    "ms": "2.1.3",
    "level-supports": "2.0.1",
    "buffer": "6.0.3",
    "http-errors": "2.0.0",
    "node-gyp": "11.5.0",
    "yargs": "17.6.2",
    "https-proxy-agent": "7.0.6",
    "which": "5.0.0",
    "emoji-regex": "9.2.2",
    "node-fetch": "2.7.0",
    "onnxruntime-common": "1.23.2"
  },
  "devDependencies": {
    "@types/clui": "^0.3.4",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-fileupload": "^1.5.1",
    "@types/express-serve-static-core": "^5.0.0",
    "@types/formidable": "^3.4.5",
    "@types/json-bigint": "^1.0.4",
    "@types/minimist": "^1.2.5",
    "@types/node": "22.7.7",
    "@types/pouchdb": "^6.4.2",
    "@types/pouchdb-find": "^7.3.3",
    "@types/progress-stream": "^2.0.5",
    "@types/sockjs": "0.3.36",
    "@types/sockjs-client": "^1.5.4",
    "@types/source-map-support": "^0.5.10",
    "@types/spinnies": "^0.5.3",
    "@types/tcp-port-used": "^1.0.4",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@types/webpack-hot-middleware": "2.25.12"
  },
  "packageManager": "yarn@4.12.0"
}
